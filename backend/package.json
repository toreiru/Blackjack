{
    "name": "blackjack-backend",
    "version": "1.0.0",
    "main": "src/server.ts",
    "scripts": {
        "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
        "build": "tsc",
        "start": "npx prisma generate && npx prisma db push --accept-data-loss && node dist/server.js"
    },
    "dependencies": {
        "@prisma/client": "^5.0.0",
        "bcrypt": "^5.1.0",
        "cors": "^2.8.5",
        "dotenv": "^16.3.1",
        "express": "^4.18.2",
        "jsonwebtoken": "^9.0.0",
        "socket.io": "^4.7.1",
        "prisma": "^5.0.0"
    },
    "devDependencies": {
        "@types/bcrypt": "^5.0.0",
        "@types/cors": "^2.8.13",
        "@types/express": "^4.17.17",
        "@types/jsonwebtoken": "^9.0.2",
        "@types/node": "^20.4.5",
        "ts-node-dev": "^2.0.0",
        "typescript": "^5.1.6"
    }
}